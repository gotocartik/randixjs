{
  "name": "randixjs",
  "version": "1.0.2",
  "description": "Modern random generation toolkit for Node.js and browsers",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --watch --format esm,cjs --dts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "random",
    "random-generator",
    "password-generator",
    "otp-generator",
    "uuid",
    "typescript",
    "utility",
    "random-string",
    "random-number"
  ],
  "author": "Karthik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gotocartik/randixjs.git"
  },
  "bugs": {
    "url": "https://github.com/gotocartik/randixjs/issues"
  },
  "homepage": "https://github.com/gotocartik/randixjs#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
